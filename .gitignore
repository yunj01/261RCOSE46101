# =====================================================================
# Korean CoT Distillation — .gitignore
# Strategy: share code + data + result JSONs. LoRA weights go to Drive.
# =====================================================================

# Model weights (4.2 GB; share separately via Google Drive / W&B)
weights/

# Virtual environments
venv/
.venv/
env/

# Python caches
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Unsloth / HF caches
unsloth_compiled_cache/
.cache/

# Logs and runtime files
logs/
*.log
*.pid
wandb/
nohup.out

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Secrets
.env
.env.local
*.key
*.pem

# Local archives
*.zip
*.tar
*.tar.gz

# Local-only run wrappers (machine-specific paths)
scripts/*.cmd
scripts/run_detached.ps1

# Legacy planning notes (kept locally only)
PLAN.md
STATUS.md
DALR_SETUP.md

# Paper build artifacts
paper_template/*.pdf
paper_template/*.aux
paper_template/*.bbl
paper_template/*.blg
paper_template/*.log
paper_template/*.out
paper_template/*.synctex.gz
